# Copy this file to .env and adjust as needed:  cp .env.example .env
# .env is gitignored so your real credentials never get committed.

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
# Database that holds our weather data (separate from Airflow's metadata DB)
WEATHER_DB_NAME=weather_data

# ── Airflow web login ────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Used to sign session cookies — set a long random value for anything non-local.
AIRFLOW_SECRET_KEY=changeme_generate_a_random_value
